---
import Calc from "../react/Calc.jsx";
const keys = [
  "Reduce labor costs by up to 60%",
  "Eliminate infrastructure expenses",
  "Lower turnover-related costs",
  "Increase ROI within the first 90 days",
];
---

<section
  id="pricing"
  class="px-8 py-40 grid grid-cols-2 max-w-7xl m-auto font-DM gap-12"
>
  <div class="flex items-center justify-start grow" data-aos="fade-down">
    <Calc client:load />
  </div>

  <div class="flex flex-col gap-8 p-8 border border-neutral-200" data-aos="fade-up">
    <div class="flex flex-col gap-2">
      <h1 class="text-6xl">
        See How Much You<br /> Can
        <span class="text-indigo-500"> Save </span>
      </h1>
      <h2 class="text-xl text-neutral-500">
        Calculate your operational savings in minutes.
      </h2>
      <ul class="flex items-center flex-wrap gap-x-4 gap-y-2 text-sm">
        {
          keys.map((k, i) => (
            <li class="px-4 py-2 text-indigo-500 bg-indigo-50 rounded-full border border-indigo-200">
              {k}
            </li>
          ))
        }
      </ul>
    </div>

    <button class="ring-2 ring-indigo-500 px-4 py-2 text-indigo-500 text-4xl font-manrope font-medium"> Get Your Analysis </button>
  </div>
</section>
